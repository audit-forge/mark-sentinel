FROM python:3.13-slim

LABEL org.opencontainers.image.title="M.A.R.K. Sentinel Agent" \
      org.opencontainers.image.description="Distributed AI security audit agent" \
      org.opencontainers.image.vendor="Hash AI" \
      org.opencontainers.image.source="https://github.com/hash-ai/sentinel"

ENV SENTINEL_SERVER="" \
    SENTINEL_AGENT_TOKEN="" \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip \
 && pip install --no-cache-dir -r requirements.txt

COPY agent.py audit.py audit_history.py alerts.py storage.py license.py tokens.py discovery.py server.py ./
COPY checks/     checks/
COPY connectors/ connectors/
COPY profiles/   profiles/
COPY output/     output/

RUN addgroup --system sentinel \
 && adduser  --system --no-create-home --ingroup sentinel sentinel \
 && chown -R sentinel:sentinel /app

USER sentinel

HEALTHCHECK --interval=120s --timeout=5s --start-period=60s --retries=3 \
    CMD test -f /app/output/.device_id

CMD ["python", "agent.py", "--daemon", "--target", "/app"]
