                "text": "Rate Limiting Configured"
              },
              "fullDescription": {
                "text": "Rate limiting configuration found in deployment files."
              },
              "helpUri": "https://github.com/audit-forge/mark-sentinel/blob/main/checks/AI-DEPLOY.md#ai-deploy-006",
