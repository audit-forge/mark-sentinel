              "properties": {
                "severity": "CRITICAL",
                "category": "AI-INP",
                "frameworks": {
                  "OWASP LLM": "LLM01",
                  "OWASP Agentic": "OAGNT-01",
                  "FedRAMP": "SI-10",
                  "NIST AI RMF": "MEASURE 2.6"
                },
                "tags": [
                  "security",
                  "ai-security",
                  "ai-inp"
                ]
              }
            },
            {
              "id": "AI-INP-002",
              "name": "DirectPromptInjectionResistance",
