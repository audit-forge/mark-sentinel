              }
            },
            {
              "id": "AI-INP-001",
              "name": "SystemPromptCannotBeOverriddenByUserInput",
              "shortDescription": {
                "text": "System Prompt Cannot Be Overridden by User Input"
              },
              "fullDescription": {
                "text": "This check requires a live AI connection to send adversarial probes. Run with --mode api or --mode local to evaluate."
              },
              "helpUri": "https://github.com/audit-forge/mark-sentinel/blob/main/checks/AI-INP.md#ai-inp-001",
              "defaultConfiguration": {
                "level": "none"
