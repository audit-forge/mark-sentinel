{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/master/Schemata/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "M.A.R.K. Sentinel",
          "version": "1.0.0-phase1",
          "informationUri": "https://github.com/audit-forge/mark-sentinel",
          "rules": [
            {
              "id": "AI-DEPLOY-001",
              "name": "ApiKeysNotExposed",
              "shortDescription": {
                "text": "API Keys Not Exposed"
              },
              "fullDescription": {
                "text": "No API keys detected in source files. .gitignore protects .env files."
              },
              "helpUri": "https://github.com/audit-forge/mark-sentinel/blob/main/checks/AI-DEPLOY.md#ai-deploy-001",
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "severity": "CRITICAL",
                "category": "AI-DEPLOY",
                "frameworks": {
                  "OWASP LLM": "LLM07",
                  "FedRAMP": "IA-5",
                  "NIST AI RMF": "MANAGE 2.2"
                },
                "tags": [
                  "security",
                  "ai-security",
                  "ai-deploy"
                ]
              }
            },
            {
              "id": "AI-DEPLOY-002",
              "name": "NoHardcodedCredentialsInModelConfig",
              "shortDescription": {
                "text": "No Hardcoded Credentials in Model Config"
              },
              "fullDescription": {
                "text": "No hardcoded credentials detected in config files."
              },
              "helpUri": "https://github.com/audit-forge/mark-sentinel/blob/main/checks/AI-DEPLOY.md#ai-deploy-002",
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "severity": "HIGH",
                "category": "AI-DEPLOY",
                "frameworks": {
                  "OWASP LLM": "LLM07",
                  "FedRAMP": "IA-5, CM-6",
                  "NIST AI RMF": "MANAGE 2.2"
                },
                "tags": [
                  "security",
                  "ai-security",
                  "ai-deploy"
                ]
              }
            },
            {
              "id": "AI-DEPLOY-003",
              "name": "LoggingEnabledAndRetained",
              "shortDescription": {
                "text": "Logging Enabled and Retained"
              },
              "fullDescription": {
                "text": "Logging configuration and retention settings found."
              },
              "helpUri": "https://github.com/audit-forge/mark-sentinel/blob/main/checks/AI-DEPLOY.md#ai-deploy-003",
              "defaultConfiguration": {
                "level": "note"
              },
              "properties": {
                "severity": "HIGH",
                "category": "AI-DEPLOY",
                "frameworks": {
                  "OWASP LLM": "LLM10",
                  "FedRAMP": "AU-2, AU-11",
                  "NIST AI RMF": "MEASURE 2.5"
                },
                "tags": [
                  "security",
                  "ai-security",
                  "ai-deploy"
                ]
              }
            },
            {
              "id": "AI-DEPLOY-004",
              "name": "AccessControlsOnAiEndpoint",
              "shortDescription": {
                "text": "Access Controls on AI Endpoint"
              },
              "fullDescription": {
                "text": "Authentication configuration found in deployment files."
              },
              "helpUri": "https://github.com/audit-forge/mark-sentinel/blob/main/checks/AI-DEPLOY.md#ai-deploy-004",
              "defaultConfiguration": {
                "level": "note"
