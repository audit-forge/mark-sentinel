                "severity": "HIGH",
                "category": "AI-DEPLOY",
                "frameworks": {
                  "OWASP LLM": "LLM08",
                  "FedRAMP": "SC-8",
                  "NIST AI RMF": "MANAGE 2.2"
                },
                "tags": [
                  "security",
                  "ai-security",
                  "ai-deploy"
                ]
              }
            },
            {
              "id": "AI-DEPLOY-006",
              "name": "RateLimitingConfigured",
