              "shortDescription": {
                "text": "Indirect Prompt Injection Resistance (RAG)"
              },
              "fullDescription": {
                "text": "Indirect/RAG injection testing requires knowledge of the target retrieval pipeline. This check is deferred to Phase 3 \u2014 supply a RAG fixture or document corpus to enable it."
              },
              "helpUri": "https://github.com/audit-forge/mark-sentinel/blob/main/checks/AI-INP.md#ai-inp-003",
              "defaultConfiguration": {
                "level": "none"
